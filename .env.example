# Optional environment overrides for Pokédex Builder.
# Copy this file to .env before editing it.

# Base endpoint used by the reusable PokéAPI client.
POKEDEX_POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Maximum duration of an HTTP request, in seconds.
POKEDEX_REQUEST_TIMEOUT_SECONDS=30

# Number of retries for temporary connection and server failures.
POKEDEX_REQUEST_RETRIES=3

# Cache lifetime in hours. Use 0 to force entries to expire immediately.
POKEDEX_CACHE_TTL_HOURS=168

# User-Agent sent to public data sources.
POKEDEX_USER_AGENT=pokedex-builder/0.1.0
